---
// Reusable inner-page hero banner with a background image + overlay.
const {
  title,
  subtitle,
  image,
  align = 'center',
  eyebrow,
} = Astro.props;
---

<section class={`page-banner page-banner--${align}`}>
  <div class="page-banner__media" style={`background-image:url('${image}')`}></div>
  <div class="page-banner__overlay"></div>
  <div class="container page-banner__inner">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h1 class="reveal is-visible">{title}</h1>
    {subtitle && <p class="page-banner__subtitle">{subtitle}</p>}
  </div>
</section>

<style>
  .page-banner {
    position: relative;
    display: grid;
    align-items: center;
    min-height: clamp(320px, 46vh, 440px);
    color: #fff;
    overflow: hidden;
  }
  .page-banner__media {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.05);
    animation: bannerZoom 14s var(--ease) forwards;
  }
  @keyframes bannerZoom {
    to { transform: scale(1); }
  }
  .page-banner__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(43, 12, 12, 0.85),
      rgba(74, 20, 20, 0.6) 60%,
      rgba(74, 20, 20, 0.45)
    );
  }
  .page-banner__inner {
    position: relative;
    padding-block: 3rem;
    max-width: 760px;
  }
  .page-banner--center {
    text-align: center;
  }
  .page-banner--center .page-banner__inner {
    margin-inline: auto;
  }
  .page-banner--center .page-banner__overlay {
    background: linear-gradient(
      to bottom,
      rgba(43, 12, 12, 0.7),
      rgba(74, 20, 20, 0.62)
    );
  }
  .page-banner h1 {
    color: #fff;
    margin-bottom: 0.6rem;
  }
  .page-banner__subtitle {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    color: #f0dcd4;
    margin: 0;
    max-width: 60ch;
  }
  .page-banner--center .page-banner__subtitle {
    margin-inline: auto;
  }
</style>
