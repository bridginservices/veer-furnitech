---
import Icon from './Icon.astro';
import { business, whatsappLink } from '../data/site.js';
---

<!-- Floating WhatsApp + click-to-call, and a back-to-top button -->
<div class="floaties" aria-hidden="false">
  <a
    class="floatie floatie--wa"
    href={whatsappLink()}
    target="_blank"
    rel="noopener"
    aria-label="Chat with us on WhatsApp"
  >
    <Icon name="whatsapp" size={28} />
    <span class="floatie__pulse"></span>
  </a>
  <a class="floatie floatie--call" href={`tel:${business.phoneRaw}`} aria-label="Call Veer Furnitech">
    <Icon name="phone" size={24} />
  </a>
</div>

<button class="back-to-top" data-back-to-top aria-label="Back to top" hidden>
  <Icon name="arrowUp" size={22} />
</button>

<style>
  .floaties {
    position: fixed;
    right: clamp(0.9rem, 2vw, 1.5rem);
    bottom: clamp(0.9rem, 2vw, 1.5rem);
    z-index: 90;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .floatie {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    color: #fff;
    box-shadow: 0 12px 28px -8px rgba(0, 0, 0, 0.4);
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }
  .floatie:hover {
    transform: translateY(-4px) scale(1.05);
  }
  .floatie--wa {
    background: #25d366;
  }
  .floatie--call {
    background: var(--maroon);
  }
  .floatie__pulse {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #25d366;
    z-index: -1;
    animation: pulse 2.2s var(--ease) infinite;
  }
  @keyframes pulse {
    0% { transform: scale(1); opacity: 0.6; }
    70% { transform: scale(1.7); opacity: 0; }
    100% { opacity: 0; }
  }

  .back-to-top {
    position: fixed;
    left: clamp(0.9rem, 2vw, 1.5rem);
    bottom: clamp(0.9rem, 2vw, 1.5rem);
    z-index: 90;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: var(--white);
    color: var(--maroon);
    cursor: pointer;
    box-shadow: var(--shadow);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.3s var(--ease), transform 0.3s var(--ease),
      background 0.25s var(--ease), color 0.25s var(--ease);
  }
  .back-to-top.is-visible {
    opacity: 1;
    transform: none;
  }
  .back-to-top:hover {
    background: var(--maroon);
    color: #fff;
  }
  @media (max-width: 560px) {
    .floatie {
      width: 52px;
      height: 52px;
    }
  }
</style>

<script>
  const btn = document.querySelector('[data-back-to-top]');
  if (btn) {
    const onScroll = () => {
      const show = window.scrollY > 500;
      btn.classList.toggle('is-visible', show);
      btn.hidden = !show;
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    btn.addEventListener('click', () =>
      window.scrollTo({ top: 0, behavior: 'smooth' })
    );
  }
</script>
