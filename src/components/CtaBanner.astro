---
import Icon from './Icon.astro';
import { business, whatsappLink } from '../data/site.js';
const {
  title = "Let's Design Your Dream Space Today",
  text = 'From a single wardrobe to a full home or office fit-out — talk to our Nagpur team and get a free design consultation.',
  primaryLabel = 'Contact Us',
  primaryHref = '/contact/',
} = Astro.props;
---

<section class="section section--maroon cta">
  <div class="container cta__inner reveal">
    <div class="cta__text">
      <span class="eyebrow">Ready when you are</span>
      <h2>{title}</h2>
      <p>{text}</p>
    </div>
    <div class="cta__actions">
      <a class="btn btn--brass btn--lg" href={primaryHref}>
        {primaryLabel} <Icon name="arrowRight" size={18} />
      </a>
      <a class="btn btn--ghost btn--lg" href={whatsappLink()} target="_blank" rel="noopener">
        <Icon name="whatsapp" size={18} /> WhatsApp
      </a>
    </div>
  </div>
</section>

<style>
  .cta__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .cta__text {
    max-width: 620px;
  }
  .cta__text h2 {
    margin-bottom: 0.5rem;
  }
  .cta__text p {
    color: #ecd6ce;
    margin: 0;
  }
  .cta__actions {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
  }
  @media (max-width: 720px) {
    .cta__actions {
      width: 100%;
    }
    .cta__actions .btn {
      flex: 1;
    }
  }
</style>
