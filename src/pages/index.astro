---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import CtaBanner from '../components/CtaBanner.astro';
import {
  services,
  serveStrip,
  testimonials,
  stats,
  business,
  whatsappLink,
} from '../data/site.js';

const slides = [
  {
    image:
      'https://images.unsplash.com/photo-1567016432779-094069958ea5?auto=format&fit=crop&w=1800&q=80',
    alt: 'Elegant living room furniture with a modern sofa set',
    heading: 'Crafting Comfort. Designing Dreams.',
    sub: 'Premium living-room furniture, made-to-measure in Nagpur.',
  },
  {
    image:
      'https://images.unsplash.com/photo-1556909212-d5b604d0c90d?auto=format&fit=crop&w=1800&q=80',
    alt: 'Modern modular kitchen with island counter',
    heading: 'Where Furniture Meets Elegance',
    sub: 'Ergonomic modular kitchens built for the way India cooks.',
  },
  {
    image:
      'https://images.unsplash.com/photo-1616594039964-ae9021a400a0?auto=format&fit=crop&w=1800&q=80',
    alt: 'Serene bedroom with a custom wardrobe and bed',
    heading: 'Bedrooms Designed Around You',
    sub: 'Smart storage and restful design, crafted to last.',
  },
];

const desc =
  'Veer Furnitech is a leading furniture manufacturer & interior designer in Nagpur. Modular kitchens, custom furniture, office & commercial interiors — from concept to installation.';
---

<BaseLayout title="Furniture & Interior Design in Nagpur" description={desc}>
  <!-- ============ HERO SLIDER ============ -->
  <section class="hero" data-hero aria-roledescription="carousel" aria-label="Featured work">
    <div class="hero__slides">
      {slides.map((slide, i) => (
        <div
          class={`hero__slide ${i === 0 ? 'is-active' : ''}`}
          data-slide
          role="group"
          aria-roledescription="slide"
          aria-label={`${i + 1} of ${slides.length}`}
        >
          <div class="hero__media" style={`background-image:url('${slide.image}')`} role="img" aria-label={slide.alt}></div>
          <div class="hero__overlay"></div>
          <div class="container hero__content">
            <span class="eyebrow">Veer Furnitech · Nagpur</span>
            <h1>{slide.heading}</h1>
            <p class="hero__sub">{slide.sub}</p>
            <div class="btn-row hero__cta">
              <a class="btn btn--brass btn--lg" href="/furniture/">Explore Furniture <Icon name="arrowRight" size={18} /></a>
              <a class="btn btn--ghost btn--lg" href="/contact/">Contact Us</a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="hero__dots" role="tablist" aria-label="Choose slide">
      {slides.map((_, i) => (
        <button
          class={`hero__dot ${i === 0 ? 'is-active' : ''}`}
          data-dot
          role="tab"
          aria-label={`Go to slide ${i + 1}`}
          aria-selected={i === 0 ? 'true' : 'false'}
        ></button>
      ))}
    </div>
    <div class="hero__scroll" aria-hidden="true"><span></span></div>
  </section>

  <!-- ============ STATS STRIP ============ -->
  <section class="stats-strip">
    <div class="container grid grid--4 stats-strip__grid">
      {stats.map((s, i) => (
        <div class="stat reveal" data-delay={i}>
          <span class="stat__value">{s.value}</span>
          <span class="stat__label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ ABOUT ============ -->
  <section class="section" id="about">
    <div class="container about">
      <div class="about__text reveal">
        <span class="eyebrow">Who we are</span>
        <h2>Furniture &amp; interior solutions, crafted under one roof</h2>
        <p>
          Veer Furnitech is a leading furniture and interior solutions company
          based in <strong>Nagpur, Maharashtra</strong>. We specialise in
          modular and customised furniture for homes and offices, offering
          complete solutions from concept to installation.
        </p>
        <p>
          With our own manufacturing facility in Hingna MIDC, we control every
          stage — design, material, build and fit-out — so you get furniture
          that's durable, elegant and delivered on time.
        </p>
        <ul class="about__list">
          <li><Icon name="check" size={18} /> Design &amp; Planning</li>
          <li><Icon name="check" size={18} /> Custom Manufacturing</li>
          <li><Icon name="check" size={18} /> Installation</li>
          <li><Icon name="check" size={18} /> Material Supply</li>
        </ul>
        <div class="btn-row">
          <a class="btn" href="/services/">Our Services <Icon name="arrowRight" size={18} /></a>
          <a class="btn btn--outline" href={`tel:${business.phoneRaw}`}><Icon name="phone" size={18} /> {business.phone}</a>
        </div>
      </div>
      <div class="about__media reveal" data-delay="2">
        <img
          src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?auto=format&fit=crop&w=1000&q=80"
          alt="Modern furnished living room designed by Veer Furnitech"
          loading="lazy"
          width="1000"
          height="1200"
        />
        <div class="about__badge">
          <span class="about__badge-num">10+</span>
          <span class="about__badge-txt">Years of<br />Craftsmanship</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SERVICES ============ -->
  <section class="section section--cream-2" id="services">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">What we do</span>
        <h2>Complete furniture &amp; interior services</h2>
        <p>Everything you need to design, build and install beautiful, functional spaces.</p>
      </div>
      <div class="grid grid--4">
        {services.map((s, i) => (
          <article class="card service-card reveal" data-delay={i}>
            <span class="service-card__icon"><Icon name={s.icon} size={26} /></span>
            <h3>{s.title}</h3>
            <p>{s.short}</p>
            <a class="service-card__link" href="/services/">Learn more <Icon name="arrowRight" size={16} /></a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ AREAS WE SERVE (marquee) ============ -->
  <section class="serve section--tight">
    <div class="serve__label container"><span class="eyebrow">Spaces we transform</span></div>
    <div class="marquee" aria-hidden="true">
      <div class="marquee__track">
        {[...serveStrip, ...serveStrip].map((item) => (
          <span class="marquee__item">{item}<span class="marquee__dot">◆</span></span>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ TESTIMONIALS ============ -->
  <section class="section" id="reviews">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">Client love</span>
        <h2>What our customers say</h2>
        <p>Real feedback from homeowners and businesses across Nagpur.</p>
      </div>
      <div class="grid grid--2 reviews">
        {testimonials.map((t, i) => (
          <figure class="card review reveal" data-delay={i % 2}>
            <span class="review__quote"><Icon name="quote" size={30} /></span>
            <div class="review__stars" aria-label={`${t.rating} out of 5 stars`}>
              {Array.from({ length: t.rating }).map(() => <Icon name="star" size={16} />)}
            </div>
            <blockquote>{t.quote}</blockquote>
            <figcaption>
              <span class="review__avatar">{t.name.charAt(0)}</span>
              <span>
                <strong>{t.name}</strong>
                <span class="review__role">{t.role}</span>
              </span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />
</BaseLayout>

<style>
  /* -------- Hero slider -------- */
  .hero {
    position: relative;
    min-height: clamp(560px, 92vh, 860px);
    color: #fff;
    overflow: hidden;
  }
  .hero__slides,
  .hero__slide {
    position: absolute;
    inset: 0;
  }
  .hero__slide {
    opacity: 0;
    visibility: hidden;
    transition: opacity 1.1s var(--ease);
    display: grid;
    align-items: center;
  }
  .hero__slide.is-active {
    opacity: 1;
    visibility: visible;
  }
  .hero__media {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.08);
    transition: transform 7s ease-out;
  }
  .hero__slide.is-active .hero__media {
    transform: scale(1);
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(36, 10, 10, 0.86) 0%,
      rgba(74, 20, 20, 0.55) 55%,
      rgba(74, 20, 20, 0.25) 100%
    );
  }
  .hero__content {
    position: relative;
    max-width: 720px;
    padding-block: 5rem;
  }
  .hero__content h1 {
    color: #fff;
    font-size: clamp(2.4rem, 6vw, 4.4rem);
    margin-bottom: 0.7rem;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
  }
  .hero__sub {
    font-size: clamp(1.1rem, 2.2vw, 1.4rem);
    color: #f2ddd4;
    max-width: 48ch;
    margin-bottom: 1.8rem;
  }
  .hero__slide.is-active h1,
  .hero__slide.is-active .hero__sub,
  .hero__slide.is-active .hero__cta {
    animation: heroUp 0.9s var(--ease) both;
  }
  .hero__slide.is-active .hero__sub { animation-delay: 0.12s; }
  .hero__slide.is-active .hero__cta { animation-delay: 0.24s; }
  @keyframes heroUp {
    from { opacity: 0; transform: translateY(26px); }
    to { opacity: 1; transform: none; }
  }
  .hero__dots {
    position: absolute;
    bottom: 1.8rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.6rem;
    z-index: 5;
  }
  .hero__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.7);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s var(--ease);
  }
  .hero__dot.is-active {
    background: var(--brass);
    border-color: var(--brass);
    width: 30px;
    border-radius: 8px;
  }
  .hero__scroll {
    position: absolute;
    bottom: 1.6rem;
    right: 2rem;
    width: 26px;
    height: 42px;
    border: 2px solid rgba(255, 255, 255, 0.55);
    border-radius: 14px;
    z-index: 5;
  }
  .hero__scroll span {
    position: absolute;
    top: 8px;
    left: 50%;
    width: 4px;
    height: 8px;
    margin-left: -2px;
    background: #fff;
    border-radius: 2px;
    animation: scrollDot 1.8s var(--ease) infinite;
  }
  @keyframes scrollDot {
    0% { opacity: 0; transform: translateY(0); }
    40% { opacity: 1; }
    100% { opacity: 0; transform: translateY(14px); }
  }
  @media (max-width: 640px) {
    .hero__scroll { display: none; }
  }

  /* -------- Stats strip -------- */
  .stats-strip {
    background: var(--maroon);
    color: #fff;
    padding-block: clamp(1.6rem, 3vw, 2.2rem);
  }
  .stat {
    text-align: center;
    padding: 0.5rem;
    border-right: 1px solid rgba(255, 255, 255, 0.14);
  }
  .stat:last-child { border-right: none; }
  .stat__value {
    display: block;
    font-family: var(--font-head);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    color: var(--brass-light);
    line-height: 1;
  }
  .stat__label {
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: #ecd6ce;
  }
  @media (max-width: 560px) {
    .stat:nth-child(2) { border-right: none; }
  }

  /* -------- About -------- */
  .about {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .about__list {
    list-style: none;
    padding: 0;
    margin: 1.4rem 0 1.8rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.7rem;
  }
  .about__list li {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 500;
  }
  .about__list :global(svg) {
    color: #fff;
    background: var(--maroon);
    border-radius: 50%;
    padding: 4px;
    flex: none;
  }
  .about__media {
    position: relative;
  }
  .about__media img {
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
    object-fit: cover;
    aspect-ratio: 4 / 5;
  }
  .about__badge {
    position: absolute;
    bottom: -22px;
    left: -22px;
    background: var(--white);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow);
    padding: 1rem 1.3rem;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    border: 1px solid var(--line);
  }
  .about__badge-num {
    font-family: var(--font-head);
    font-size: 2.4rem;
    font-weight: 700;
    color: var(--maroon);
    line-height: 1;
  }
  .about__badge-txt {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--muted);
  }
  @media (max-width: 820px) {
    .about {
      grid-template-columns: 1fr;
    }
    .about__media {
      order: -1;
      max-width: 460px;
    }
  }

  /* -------- Service cards -------- */
  .service-card {
    padding: 1.8rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .service-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--maroon), var(--maroon-dark));
    color: #fff;
    margin-bottom: 0.6rem;
    transition: transform 0.3s var(--ease);
  }
  .service-card:hover .service-card__icon {
    transform: rotate(-6deg) scale(1.08);
  }
  .service-card h3 {
    margin: 0;
    font-size: 1.2rem;
  }
  .service-card p {
    color: var(--muted);
    font-size: 0.94rem;
    margin: 0;
    flex: 1;
  }
  .service-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.6rem;
    color: var(--maroon);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .service-card__link :global(svg) {
    transition: transform 0.25s var(--ease);
  }
  .service-card__link:hover :global(svg) {
    transform: translateX(4px);
  }

  /* -------- Marquee -------- */
  .serve {
    background: var(--maroon-dark);
    color: #fff;
    overflow: hidden;
  }
  .serve__label {
    margin-bottom: 1rem;
  }
  .serve .eyebrow { color: var(--brass-light); margin: 0; }
  .marquee {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);
  }
  .marquee__track {
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    animation: scroll-x 26s linear infinite;
  }
  .marquee:hover .marquee__track {
    animation-play-state: paused;
  }
  .marquee__item {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-head);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.92);
    padding: 0 1.5rem;
  }
  .marquee__dot {
    color: var(--brass);
    font-size: 0.7em;
    margin-left: 2.6rem;
  }
  @keyframes scroll-x {
    to { transform: translateX(-50%); }
  }

  /* -------- Reviews -------- */
  .review {
    position: relative;
    padding: 2rem 1.8rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .review__quote {
    position: absolute;
    top: 1.2rem;
    right: 1.4rem;
    color: var(--cream-2);
  }
  .review__stars {
    display: flex;
    gap: 2px;
    color: var(--brass);
  }
  .review__stars :global(svg) {
    fill: var(--brass);
  }
  .review blockquote {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.7;
    color: var(--ink);
  }
  .review figcaption {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 0.4rem;
  }
  .review__avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--maroon), var(--maroon-dark));
    color: #fff;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 1.2rem;
    flex: none;
  }
  .review figcaption strong {
    display: block;
    font-size: 0.98rem;
  }
  .review__role {
    font-size: 0.85rem;
    color: var(--muted);
  }
</style>

<script>
  // Hero auto-slider
  const hero = document.querySelector('[data-hero]');
  if (hero) {
    const slides = Array.from(hero.querySelectorAll('[data-slide]'));
    const dots = Array.from(hero.querySelectorAll('[data-dot]'));
    let idx = 0;
    let timer;
    const INTERVAL = 5500;

    const go = (n) => {
      slides[idx].classList.remove('is-active');
      dots[idx]?.classList.remove('is-active');
      dots[idx]?.setAttribute('aria-selected', 'false');
      idx = (n + slides.length) % slides.length;
      slides[idx].classList.add('is-active');
      dots[idx]?.classList.add('is-active');
      dots[idx]?.setAttribute('aria-selected', 'true');
    };
    const next = () => go(idx + 1);
    const start = () => {
      stop();
      timer = window.setInterval(next, INTERVAL);
    };
    const stop = () => timer && window.clearInterval(timer);

    dots.forEach((dot, i) =>
      dot.addEventListener('click', () => {
        go(i);
        start();
      })
    );
    hero.addEventListener('mouseenter', stop);
    hero.addEventListener('mouseleave', start);
    document.addEventListener('visibilitychange', () =>
      document.hidden ? stop() : start()
    );
    if (slides.length > 1) start();
  }
</script>
