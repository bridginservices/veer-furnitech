---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageBanner from '../components/PageBanner.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Icon from '../components/Icon.astro';
import { services } from '../data/site.js';

// Pair each service with a supporting image (order matches data/site.js).
const images = [
  'https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?auto=format&fit=crop&w=1100&q=80',
  'https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&w=1100&q=80',
  'https://images.unsplash.com/photo-1524758631624-e2822e304c36?auto=format&fit=crop&w=1100&q=80',
  'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1100&q=80',
];
const alts = [
  'Interior designer reviewing plans and material samples',
  'Plywood, laminates and finishes ready for supply',
  'Custom furniture being manufactured in the workshop',
  'Team installing modular furniture on site',
];

const desc =
  'Complete interior & furniture services in Nagpur — interior design & planning, material supply, custom manufacturing and professional installation, all under one roof.';
---

<BaseLayout title="Interior & Furniture Services in Nagpur" description={desc}>
  <PageBanner
    eyebrow="Our Services"
    title="Complete Interior & Furniture Solutions Under One Roof"
    subtitle="From the first sketch to the final screw — we design, manufacture and install everything your space needs."
    image="https://images.unsplash.com/photo-1616486338812-3dadae4b4ace?auto=format&fit=crop&w=1800&q=80"
  />

  <section class="section">
    <div class="container">
      <div class="section-head center">
        <span class="eyebrow">How we help</span>
        <h2>Four services, one seamless experience</h2>
        <p>Because everything happens in-house, you get one accountable team and a consistent, premium finish.</p>
      </div>

      <div class="svc-list">
        {services.map((s, i) => (
          <article class={`svc-row reveal ${i % 2 === 1 ? 'svc-row--flip' : ''}`}>
            <div class="svc-row__media">
              <img src={images[i]} alt={alts[i]} loading="lazy" width="1100" height="800" />
              <span class="svc-row__num">{String(i + 1).padStart(2, '0')}</span>
            </div>
            <div class="svc-row__body">
              <span class="svc-row__icon"><Icon name={s.icon} size={26} /></span>
              <h3>{s.title}</h3>
              <p>{s.short}</p>
              <ul class="svc-row__steps">
                {s.steps.map((step) => (
                  <li><Icon name="check" size={16} /> {step}</li>
                ))}
              </ul>
              <a class="btn btn--outline" href="/contact/">Enquire about this <Icon name="arrowRight" size={16} /></a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner
    title="Get Expert Interior Solutions Today"
    text="Book a free consultation with our Nagpur team and receive a tailored plan and quote for your home or office."
    primaryLabel="Contact Page"
  />
</BaseLayout>

<style>
  .svc-list {
    display: grid;
    gap: clamp(2.5rem, 6vw, 5rem);
  }
  .svc-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.6rem, 4vw, 3.5rem);
    align-items: center;
  }
  .svc-row--flip .svc-row__media {
    order: 2;
  }
  .svc-row__media {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .svc-row__media img {
    width: 100%;
    aspect-ratio: 11 / 8;
    object-fit: cover;
    transition: transform 0.6s var(--ease);
  }
  .svc-row:hover .svc-row__media img {
    transform: scale(1.05);
  }
  .svc-row__num {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-family: var(--font-head);
    font-size: 2.6rem;
    font-weight: 700;
    color: #fff;
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.4);
    opacity: 0.9;
  }
  .svc-row__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--maroon), var(--maroon-dark));
    color: #fff;
    margin-bottom: 1rem;
  }
  .svc-row__body h3 {
    font-size: clamp(1.4rem, 2.6vw, 1.9rem);
    margin-bottom: 0.5rem;
  }
  .svc-row__body > p {
    color: var(--muted);
    margin-bottom: 1.1rem;
  }
  .svc-row__steps {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: grid;
    gap: 0.6rem;
  }
  .svc-row__steps li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.96rem;
  }
  .svc-row__steps :global(svg) {
    color: #fff;
    background: var(--brass);
    border-radius: 50%;
    padding: 3px;
    flex: none;
  }
  @media (max-width: 820px) {
    .svc-row,
    .svc-row--flip {
      grid-template-columns: 1fr;
    }
    .svc-row--flip .svc-row__media {
      order: -1;
    }
  }
</style>
